# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pharmacy_db

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Security
BCRYPT_ROUNDS=12

# Frontend
FRONTEND_URL=http://localhost:3000

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_PRODUCT_MB=5
MAX_FILE_SIZE_PRESCRIPTION_MB=10

# Email (optional — if not set, emails are logged to console)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Pharmacy <noreply@pharmacy.com>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
UPLOAD_RATE_LIMIT_MAX=10

# Payment webhook secret (HMAC verification)
WEBHOOK_SECRET=change-this-webhook-secret

# Logging
LOG_LEVEL=info
